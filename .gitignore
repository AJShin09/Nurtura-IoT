# ── Build artifacts ──────────────────────────────────────────────────────────
*.d
*.o *.ko *.obj *.elf
*.ilk *.map *.exp
*.gch *.pch
*.lib *.a *.la *.lo
*.dll *.so *.so.* *.dylib
*.exe *.out *.app *.i*86 *.x86_64 *.hex
*.dSYM/ *.su *.idb *.pdb
*.mod* *.cmd
.tmp_versions/
modules.order
Module.symvers
Mkfile.old
dkms.conf
*.dwo

# ── Secrets and certificates ─────────────────────────────────────────────────
# All secrets.h and cert.h files everywhere in the repo are gitignored.
# Use secrets.h.example as the committed template.
**/secrets.h
**/cert.h

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/

# ── Test reports (generated, not source) ─────────────────────────────────────
# reports/ directory is the canonical output; root-level copy is stale.
iot-test-system/pytest_report.html
iot-test-system/logs/

# ── Editor / OS ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
